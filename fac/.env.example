# FAC - Frappe AI Connector Environment Configuration

# App
APP_NAME=KCSC_AI_FAC
APP_ENV=production
DEBUG=false
SECRET_KEY=your-256-bit-secret-key-here
API_V1_PREFIX=/api/v1

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/kcsc_ai
SYNC_DATABASE_URL=postgresql://user:password@localhost:5432/kcsc_ai

# Redis (session store / blacklist / pub-sub)
REDIS_URL=redis://localhost:6379/0

# ERPNext
ERPNEXT_URL=https://your-erpnext-instance.com
ERPNEXT_API_KEY=your-erpnext-api-key
ERPNEXT_API_SECRET=your-erpnext-api-secret

# AI Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEFAULT_AI_PROVIDER=anthropic
DEFAULT_AI_MODEL=claude-sonnet-4-6

# WebSocket
WS_HEARTBEAT_INTERVAL=30

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","https://your-domain.com"]

# File Storage
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=["pdf","png","jpg","jpeg","xlsx","xls","csv","docx"]

# OTP
OTP_ISSUER=KCSC_AI
OTP_VALIDITY_SECONDS=300
